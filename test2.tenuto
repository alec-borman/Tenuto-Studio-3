tenuto "3.0" {

  %% ==============================================================================
  %% 1. CONFIGURATION PHASE (The Physics Space)
  %% ==============================================================================
  meta @{
    title: "Dawn of the Logic Layer - Opus 1",
    composer: "AI Master Composer",
    tempo: 88,
    time: "4/4",
    key: "C",
    humanize: 0.05,
    auto_pad_voices: true
  }

  %% V3.0 RELATIVE PITCH for the Right Hand contour tracking
  def rh "Right Hand" style=relative patch="gm_piano"
  %% STANDARD PITCH for the Left Hand foundation
  def lh "Left Hand"  style=standard patch="gm_piano"

  %% ==============================================================================
  %% SECTION A: The Awakening (Measures 1-8)
  %% The original delicate theme, expanding into a wider, flowing texture.
  %% ==============================================================================
  measure 1-4 {
    rh: <[
      v1: r:2 | v2: r:2
    ]>
  }

  measure 5 {
    rh: <[
      v1: c5:4.slur d5:8 e5:4.tie e5:8 |
      v2: e4:4.p g4:8 c5:4.f c5:8 |
    ]>
  }

  measure 6 {
    rh: <[
      v1: <[ c5:8 d5:8 e5:8 ]>:3/2 f5:4 g5:4 |
      v2: c4:4.grace d4:4 e4:4 f4:4 |
    ]>
  }

  measure 7 {
    rh: <[
      v1: c4:8 d4:8.cross(lh) e4:8.cross(lh) f4:8 |
      v2: c3:2 g3:2 |
    ]>
  }
}
